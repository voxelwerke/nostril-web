{
  "name": "nostril",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "concurrently -n web,api,worker -c cyan,magenta,yellow \"pnpm --filter @nostril/web dev\" \"pnpm --filter @nostril/api dev\" \"pnpm --filter @nostril/worker dev\"",
    "build": "pnpm -r build",
    "migrate": "pnpm --filter @nostril/api migrate",
    "migrate:sqlite": "pnpm --filter @nostril/shared migrate:sqlite",
    "start:web": "pnpm migrate && pnpm --filter @nostril/api start",
    "start:worker": "pnpm --filter @nostril/worker start",
    "check": "pnpm -r check"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
