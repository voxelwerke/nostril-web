# Local raw PostgreSQL 18. Defaults to postgres://localhost:5432/nostril if unset,
# and `pnpm migrate` creates the database automatically. sslmode=require flips on SSL for DO.
DATABASE_URL=postgres://localhost:5432/nostril

# API
PORT=8080
RELAYS=wss://nos.lol,wss://relay.primal.net,wss://purplepag.es
QLEN=10

# Worker: Nostr
NOSTR_RELAYS=wss://nos.lol,wss://relay.primal.net,wss://relay.snort.social,wss://nostr-pub.wellorder.net,wss://purplepag.es
BATCH_SIZE=500
FIREHOSE=true

# Worker: Mastodon
MASTODON_INSTANCES=mastodon.nz
MASTODON_POLL_INTERVAL_MS=300000

# Worker: RSS
OPML_PATH=packages/worker/feeds.opml
RSS_POLL_INTERVAL_MS=1800000

# Worker: retention (nightly DELETE sweep of post tables)
RETENTION_DAYS=28
RETENTION_SWEEP_INTERVAL_MS=86400000

# One-time SQLite import (packages/shared migrate:sqlite)
SQLITE_PATH=./nostr-users.db
